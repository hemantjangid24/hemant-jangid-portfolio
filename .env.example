# ============================================================
# Portfolio Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# EmailJS (for contact form — sign up at emailjs.com)
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# OR Formspree (simpler — sign up at formspree.io)
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/your_form_id

# Analytics (optional — Google Analytics)
VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Your info (optional — can also edit data.js directly)
VITE_PUBLIC_EMAIL=aryan.sharma@email.com
VITE_PUBLIC_GITHUB=https://github.com/aryan-sharma
VITE_PUBLIC_LINKEDIN=https://linkedin.com/in/aryan-sharma
